{
    "name": "darkterminal/docverter-patch",
    "description": "A versatile PHP package for document conversion between various formats. - patch from jumbaeric/docverter",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Eric Jumba",
            "email": "jumbaeric@gmail.com"
        },
		{
	   		"name": "panggilmeiam",
	   		"email": "darkterminal@duck.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-imagick": "*",
        "spatie/pdf-to-text": "^1.55",
        "spatie/pdf-to-image": "^3.1",
        "dompdf/dompdf": "^3.0",
        "phpoffice/phpspreadsheet": "^1.29",
        "phpoffice/phpword": "^1.3",
        "spatie/image": "^3.8",
        "spatie/temporary-directory": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "DocVerter\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/darkterminal/docverter-patch"
        }
    ]
}
